# Supabase (get from your project dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Anthropic (powers Folio AI "what to read next" recommendations)
# Free tier: 3 recs/week.  Pro/Book Club: 30 recs/day (effectively unlimited).
# Limits are enforced server-side via internal.consume_quota — see lib/quota.ts
# Get a production key at console.anthropic.com. Set a billing alert.
ANTHROPIC_API_KEY=your-anthropic-key

# Google Books (OPTIONAL — fallback provider for Goodreads imports)
# Without a key: 1000 req/day per IP (enough for ~100 user imports)
# With a key:    100k req/day (recommended once you have real users)
# Get one at: https://console.cloud.google.com → APIs & Services → Credentials → Create API Key
# Then restrict it to the "Books API" only.
NEXT_PUBLIC_GOOGLE_BOOKS_API_KEY=

# PostHog (analytics + feature flags)
# Get the project key at posthog.com → Project Settings → Project API Key
# Host depends on region: https://us.i.posthog.com or https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Supabase service role (server-only, bypasses RLS)
# Used only by the Stripe webhook handler to update billing columns.
# NEVER expose to the client — no NEXT_PUBLIC_ prefix on this one.
# Get it from Supabase dashboard → Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (server-only secret)
# Test mode: starts with sk_test_  •  Live mode: starts with sk_live_
# Get from dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=
# Stripe webhook signing secret — verifies that webhook POSTs really came from Stripe.
# Get from dashboard.stripe.com → Developers → Webhooks → your endpoint → Reveal signing secret
STRIPE_WEBHOOK_SECRET=
# Stripe Price IDs (public — they're meant to appear in checkout URLs)
# Get from dashboard.stripe.com → Products → your product → pricing → API ID (price_*)
NEXT_PUBLIC_STRIPE_PRICE_PRO=
NEXT_PUBLIC_STRIPE_PRICE_BOOK_CLUB=

# Public site URL (used as a fallback for Stripe success/cancel URLs when
# the Origin header isn't available, e.g. server-rendered redirects).
NEXT_PUBLIC_SITE_URL=https://foliotbr.app
